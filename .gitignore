# ── Dependencies ───────────────────────────────
node_modules/

# ── Expo / React Native ────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# Native build directories ( regenerated by prebuild ) — root-anchored so the
# rule does NOT also match modules/*/android, which holds committed native
# source (the adhan-player Expo module).
/ios/
/android/

# Native signing & certs
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# ── Debug / Logs ───────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ── macOS ──────────────────────────────────────
.DS_Store
*.pem

# ── Environment / Secrets ──────────────────────
.env
.env.*
!.env.example

# Firebase service account JSON (FCM v1 push credential — uploaded to EAS, NEVER commit)
*firebase-adminsdk*.json
*-firebase-adminsdk-*.json
# Generic Google/GCP service-account credentials (defense in depth)
*service-account*.json
*serviceaccount*.json
# Android CLIENT config (project id, app id, package-restricted API key). Kept out
# of git, but EAS Build STILL bundles it because .easignore omits this entry.
# Regenerate locally: node tools/scripts/fetch-google-services.mjs <service-account.json>
google-services.json

# ── Editors / IDEs ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── AI Assistants Config ───────────────────────
# Ignore local/secret config but keep the project knowledge base (rules/commands/skills)
# tracked — CLAUDE.md links to these files and they must travel with the repo.
.claude/*
!.claude/rules/
!.claude/commands/
!.claude/skills/
.claude/settings.local.json
.opencode/
.sisyphus/

# ── Docs / Audit Reports (local, not committed) ──
docs/*
!docs/privacy-policy.md
!docs/__tests__/
!docs/__tests__/privacyPolicy.test.ts

# ── TypeScript ─────────────────────────────────
*.tsbuildinfo

# ── Testing ────────────────────────────────────
coverage/

# ── Supabase ───────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Misc ───────────────────────────────────────
*.tar.gz

# ── Local scratch (gh pr diff dumps, scratch notes) ──
*.diff
!docs/**/*.diff

# ── Local-only secrets (never commit) ──
*.local
.cron-secret*

# ── Audio masters (raw full-length recordings; trimmed <=30s clips ship in
#    assets/sounds/ + modules/adhan-player/.../res/raw/). Local-only, not committed. ──
/audio-masters/
