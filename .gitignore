# ── Dependencies ───────────────────────────────
node_modules/

# ── Expo / React Native ────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# Native build directories ( regenerated by prebuild )
ios/
android/

# Native signing & certs
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# ── Debug / Logs ───────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ── macOS ──────────────────────────────────────
.DS_Store
*.pem

# ── Environment / Secrets ──────────────────────
.env
.env.*
!.env.example

# ── Editors / IDEs ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── AI Assistants Config ───────────────────────
# Ignore local/secret config but keep the project knowledge base (rules/commands/skills)
# tracked — CLAUDE.md links to these files and they must travel with the repo.
.claude/*
!.claude/rules/
!.claude/commands/
!.claude/skills/
.claude/settings.local.json
.opencode/
.sisyphus/

# ── Docs / Audit Reports (local, not committed) ──
docs/

# ── TypeScript ─────────────────────────────────
*.tsbuildinfo

# ── Testing ────────────────────────────────────
coverage/

# ── Supabase ───────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Misc ───────────────────────────────────────
*.tar.gz

# ── Local scratch (gh pr diff dumps, scratch notes) ──
*.diff
!docs/**/*.diff

# ── Local-only secrets (never commit) ──
*.local
.cron-secret*
