{
  "expo": {
    "name": "Adhan Time",
    "slug": "adhan-time",
    "version": "0.2.0",
    "icon": "./assets/images/icon.png",
    "orientation": "portrait",
    "scheme": "adhantime",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0D18",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adhantime.app",
      "backgroundColor": "#0A0D18",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.adhantime.app",
      "backgroundColor": "#0A0D18",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0E2C1E"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#040806"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10B981",
          "sounds": ["./assets/sounds/notification.wav"]
        }
      ],
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Adhan Time needs your location to compute the Qibla direction (toward the Kaaba) and show the bearing on a compass."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "0c7ed0e3-6aad-490f-b042-0616031622b9"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "mrbeko",
    "runtimeVersion": "1.2.0",
    "updates": {
      "url": "https://u.expo.dev/0c7ed0e3-6aad-490f-b042-0616031622b9"
    }
  }
}
