# .easignore — controls which files are uploaded to EAS Build.
# When this file exists, EAS uses it INSTEAD of .gitignore for the build archive.
# It mirrors .gitignore EXACTLY, with one deliberate difference: it does NOT ignore
# google-services.json, so the Android FCM client config (kept out of git) is still
# baked into the build. The admin-SDK service-account key stays ignored here too —
# it must never be uploaded to EAS Build.

# ── Dependencies ───────────────────────────────
node_modules/

# ── Expo / React Native ────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# Native build directories ( regenerated by prebuild )
/ios/
/android/

# Native signing & certs
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# ── Debug / Logs ───────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ── macOS ──────────────────────────────────────
.DS_Store
*.pem

# ── Environment / Secrets ──────────────────────
.env
.env.*
!.env.example

# Firebase service account JSON (FCM v1 push credential) — NEVER upload to EAS.
*firebase-adminsdk*.json
*-firebase-adminsdk-*.json
# NOTE: google-services.json is intentionally NOT listed here, so EAS Build bundles it.

# ── Editors / IDEs ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── AI Assistants Config ───────────────────────
.claude/
.opencode/
.sisyphus/

# ── Docs / Audit Reports (local) ──
docs/*
!docs/privacy-policy.md
!docs/__tests__/
!docs/__tests__/privacyPolicy.test.ts

# ── TypeScript ─────────────────────────────────
*.tsbuildinfo

# ── Testing ────────────────────────────────────
coverage/

# ── Supabase ───────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Misc ───────────────────────────────────────
*.tar.gz

# ── Local scratch ──
*.diff
!docs/**/*.diff

# ── Local-only secrets (never commit / upload) ──
*.local
.cron-secret*

# ── Audio masters (raw full-length recordings) ──
/audio-masters/
