{
  "name": "adhan-time",
  "version": "0.2.0",
  "private": true,
  "description": "Worldwide Muslim prayer-times (adhan) app with offline-capable local + server-backed push notifications and a qibla compass. React Native + Expo (Expo Router) + Supabase.",
  "license": "MIT",
  "author": "Berkay Kaplan (https://github.com/MrBekoX)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrBekoX/adhan-time.git"
  },
  "homepage": "https://github.com/MrBekoX/adhan-time#readme",
  "bugs": {
    "url": "https://github.com/MrBekoX/adhan-time/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "device": "expo start --dev-client",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "build:supabase-i18n": "node tools/scripts/build-supabase-i18n.js",
    "validate:build-env": "node tools/scripts/validate-build-env.js",
    "secrets:scan": "node tools/scripts/scan-secrets.mjs --all",
    "eas-build-pre-install": "node tools/scripts/validate-build-env.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "expo": "^54.0.34",
    "expo-application": "~7.0.8",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-intent-launcher": "~13.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "geomagnetism": "^0.2.0",
    "i18next": "^23.16.0",
    "intl-pluralrules": "^2.0.1",
    "js-sha256": "^0.11.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node tools/scripts/lint-staged-eslint.mjs"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.claude/worktrees/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.claude/worktrees/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))"
    ]
  }
}
