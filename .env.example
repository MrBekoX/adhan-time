EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# S1: shared secret HMAC for register-device requests.
# Mobile signs the JSON body with HMAC-SHA256(EXPO_PUBLIC_REGISTER_HMAC_KEY, body)
# and the edge function verifies against REGISTER_HMAC_KEY. Both values MUST
# match. Leave both unset to skip HMAC verification (validation + IP rate-limit
# still apply). When set, the secret is bundled into the APK so it is *tamper
# resistance* against random scanners — not authentication.
# EXPO_PUBLIC_REGISTER_HMAC_KEY=set-in-production
