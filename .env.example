EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Client proof key for register/unregister device requests.
# Mobile signs the JSON body with HMAC-SHA256(EXPO_PUBLIC_REGISTER_HMAC_KEY, body)
# and the edge functions verify against REGISTER_HMAC_KEY. Both values MUST
# match; the edge functions fail closed when REGISTER_HMAC_KEY is missing.
# The public value is bundled into the APK, so this is abuse friction against
# random scanners rather than a real user-authentication secret.
# EXPO_PUBLIC_REGISTER_HMAC_KEY=set-in-production
